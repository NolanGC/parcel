 const maybeResolveProjectId = (source: BranchSource): string | undefined => {
+  // The engine's adoption probe passes raw plan props as `olds`, where
+  // `project` can still be an unresolved primitive placeholder rather than
+  // a Project object — `"projectId" in <primitive>` throws TypeError.
+  if (typeof source !== "object" || source === null) {
+    return undefined;
+  }
   if ("projectId" in source && source.projectId) {
     return source.projectId as unknown as string;
   }
