{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 80,
  "endOfLine": "lf",
  "ternaries": true,
  "experimental_sort_imports": {
    "order": "asc"
  },
  "ignorePatterns": [
    ".alchemy/**",
    "repos/**",
    "dist/**",
    "frontend/dist/**",
    "node_modules/**",
    "*.min.js",
    "**/lib/**",
    "**/mdx/**",
    "**/*.mdx",
    "**/*.md",
    "**/.vendor/**",
    "**/package.json",
    "packages/create-foldkit-alchemy-app/templates/**",
    "packages/create-foldkit-alchemy-app/dist/**",
    "**/*.tsbuildinfo"
  ]
}
