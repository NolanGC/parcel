{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "parcel",
  "version": "0.1.0",
  "identifier": "dev.foldkit.parcel",
  "build": {
    "devUrl": "http://localhost:1337",
    "frontendDist": "../../../frontend/dist",
    "beforeBuildCommand": "bun run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "parcel",
        "width": 1100,
        "height": 750,
        "minWidth": 480,
        "minHeight": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
