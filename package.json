{
  "name": "parcel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend",
    "packages/desktop"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "alchemy deploy --stage production",
    "dev": "alchemy dev",
    "dev:desktop": "bun run --cwd packages/desktop dev",
    "build:desktop": "bun run --cwd packages/desktop build",
    "dev:branch": "alchemy dev --stage pr-$(git branch --show-current | tr '[:upper:]/_' '[:lower:]--' | tr -cd 'a-z0-9-')",
    "deploy:branch": "alchemy deploy --stage pr-$(git branch --show-current | tr '[:upper:]/_' '[:lower:]--' | tr -cd 'a-z0-9-')",
    "destroy:branch": "alchemy destroy --stage pr-$(git branch --show-current | tr '[:upper:]/_' '[:lower:]--' | tr -cd 'a-z0-9-')",
    "clear": "pkill -f 'workerd serve' || true",
    "destroy": "alchemy destroy",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --disable-nested-config .",
    "lint:fix": "oxlint --disable-nested-config --fix .",
    "test": "bun run --cwd frontend test",
    "test:integ": "INTEG=1 bun test test/integ.test.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250805.0",
    "@effect/platform-bun": "4.0.0-beta.88",
    "@effect/platform-node": "4.0.0-beta.88",
    "@effect/sql-pg": "4.0.0-beta.88",
    "alchemy": "2.0.0-beta.59",
    "better-auth": "^1.6.23",
    "drizzle-orm": "1.0.0-rc.1",
    "effect": "4.0.0-beta.88",
    "pg": "^8.13.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "1.0.0-rc.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  },
  "overrides": {
    "@distilled.cloud/cloudflare-runtime": "0.12.0",
    "@distilled.cloud/cloudflare-vite-plugin": "0.12.0",
    "@distilled.cloud/cloudflare-rolldown-plugin": "0.12.0"
  },
  "patchedDependencies": {
    "alchemy@2.0.0-beta.59": "patches/alchemy@2.0.0-beta.59.patch"
  }
}
